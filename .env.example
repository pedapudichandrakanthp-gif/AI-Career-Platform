# Supabase project URL. Safe for browser use because Supabase anon access is still protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous public key. Safe for browser use; never use it to bypass database policies.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Server-only secret for privileged backend operations; never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Groq API key. Server-only secret used by backend AI services; never expose it to the browser.
GROQ_API_KEY=

# (Legacy) OpenAI API key. The project currently uses Groq.
# OPENAI_API_KEY=

# Admin user email for accessing the manual job posting page at the root URL.
NEXT_PUBLIC_ADMIN_EMAIL=
